#!/bin/bash
# Copyright (c) 2026 quatric - quatricsoftware@gmail.com
set -e

# Get the directory of this script
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Export paths
if [ -f "$DIR/../../ffmpeg.exe" ]; then
    export FFMPEG="$DIR/../../ffmpeg.exe"
else
    export FFMPEG="$DIR/../../ffmpeg"
fi
export OUTDIR="$DIR/tmp_output"

mkdir -p "$OUTDIR"

cd "$DIR"

if [ ! -f "stupi.mp4" ]; then
    echo "Error: stupi.mp4 must be present in $DIR"
    exit 1
fi

export ENCODE_PY="$DIR/../../encode.py"

if [ ! -f "$ENCODE_PY" ]; then
    echo "Error: encode.py must be present in $DIR/../../"
    exit 1
fi

echo "Running encoding & decoding tests using encode.py..."

"$ENCODE_PY" mods adpcm >/dev/null 2>&1
"$ENCODE_PY" mods pcm >/dev/null 2>&1
"$ENCODE_PY" mods fastaudio >/dev/null 2>&1
"$ENCODE_PY" moflex3d pcm >/dev/null 2>&1
"$ENCODE_PY" moflex3d fastaudio >/dev/null 2>&1
"$ENCODE_PY" moflex3d adpcm >/dev/null 2>&1
"$ENCODE_PY" moflex pcm >/dev/null 2>&1
"$ENCODE_PY" moflex fastaudio >/dev/null 2>&1
"$ENCODE_PY" moflex adpcm >/dev/null 2>&1
"$ENCODE_PY" mo adpcm >/dev/null 2>&1
"$ENCODE_PY" mo vorbis >/dev/null 2>&1
"$ENCODE_PY" mo fastaudio >/dev/null 2>&1
"$ENCODE_PY" mo pcm >/dev/null 2>&1

echo "Verifying container hashes..."

# Note: We only hash the encoded containers. The decoded .mp4 files are verified to succeed 
# by the exit code of encode.py, but their exact sha1 hashes are omitted here because the 
# ffmpeg AAC/mpeg4 encoders introduce slight non-determinism across runs.
cat << 'HASHES' > "$OUTDIR/expected_hashes.txt"
c30c2937d4e65b0622cd3d9749f7c04ae21c22e3  roundtrip_mods_adpcm.mods
ad24a459ee4361541c29b39440939fe39e9649b0  roundtrip_mods_pcm.mods
90ae8182f885c617441aadee227ce37dc0196999  roundtrip_mods_fastaudio.mods
3f135ae95a7aaae3213ba6c317623dc81efbaf48  roundtrip_moflex3d_pcm.moflex
9e96c6040b55a85ee867b2d970b89378117fffb3  roundtrip_moflex3d_fastaudio.moflex
e7f794768f887018bc6bc8f800936e667b733f53  roundtrip_moflex3d_adpcm.moflex
ecfd8179bc144b46af1ff3846af4540669e81999  roundtrip_moflex_pcm.moflex
6e26854f4a6528ee1bbef3fcdfcd072321f67ebb  roundtrip_moflex_fastaudio.moflex
38209d2aea784d8d3cca17d8da90c9d740b87422  roundtrip_moflex_adpcm.moflex
84fbb1bf713fd1672d176ef55a5b65dd253a5af8  roundtrip_mo_adpcm.mo
28efcc326d08ad2e4b6fd65d1bbf05b37f32b2a8  roundtrip_mo_vorbis.mo
6519f779ed29fb68b469081487f62df229ed5544  roundtrip_mo_fastaudio.mo
a96562fa62c73541ff3713d199388d2f6a58513b  roundtrip_mo_pcm.mo
HASHES

cd "$OUTDIR"

if shasum -c expected_hashes.txt; then
    echo "All tests passed successfully! ✅"
    exit 0
else
    echo "Hash verification failed! ❌"
    exit 1
fi
